# Copy this file to .env and fill in your values. Never commit .env.
ANTHROPIC_API_KEY=
PORT=8787
ALLOWED_ORIGIN=http://localhost:5173
# Model ID — verify/update to a current Sonnet model before deployment
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_DOC_CHARS=200000

# ── OpenAI (embeddings for RAG pipeline) ────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase (server-side access for RAG ingestion + retrieval) ─────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key — offline backfill script ONLY. Never deploy to a
# request-serving context or expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# ── RAG tuning (all optional — sensible defaults in code) ───────────────────
# RAG_TOP_K=8
# RAG_CHUNK_SIZE=3000
# RAG_CHUNK_OVERLAP=400
# RAG_BROAD_CHAR_BUDGET=480000
