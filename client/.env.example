# Copy to .env and set the URL of your running backend.
# Changing this value requires a frontend rebuild/redeploy (Vite inlines it at build time).
VITE_API_URL=http://localhost:8787

# Supabase — from your project's Settings > API page.
# The anon key is safe to expose in the client bundle (RLS is the security boundary).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
